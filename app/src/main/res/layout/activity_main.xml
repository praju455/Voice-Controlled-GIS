<?xml version="1.0" encoding="utf-8"?>
<!--
    Veer Rakshak — Main Activity Layout
    Root: DrawerLayout (enables sidebar swipe from left)
-->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    tools:context=".MainActivity">

    <!-- ════════════════════════════════════════════
         MAIN CONTENT (map + overlaid HUD cards)
         ════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Full-screen map -->
        <com.mapbox.mapboxsdk.maps.MapView
            android:id="@+id/mapView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- ── TOP BAR ─────────────────────────────── -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/topBar"
            android:layout_width="0dp"
            android:layout_height="@dimen/topbar_height"
            android:background="@drawable/bg_topbar"
            android:elevation="8dp"
            android:paddingHorizontal="@dimen/topbar_padding_horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_action_button"
                android:contentDescription="@string/menu_description"
                android:padding="12dp"
                android:src="@drawable/ic_menu"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <FrameLayout
                android:id="@+id/topBarLogoPlate"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_semi_circle_plate"
                android:paddingStart="7dp"
                android:paddingTop="6dp"
                android:paddingEnd="6dp"
                android:paddingBottom="6dp"
                app:layout_constraintBottom_toBottomOf="@id/btnMenu"
                app:layout_constraintStart_toEndOf="@id/btnMenu"
                app:layout_constraintTop_toTopOf="@id/btnMenu">

                <ImageView
                    android:id="@+id/topBarLogo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="Logo"
                    android:scaleType="fitCenter"
                    android:src="@drawable/veer_rakshak_logo" />
            </FrameLayout>

            <TextView
                android:id="@+id/topBarTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:ellipsize="end"
                android:fontFamily="monospace"
                android:letterSpacing="0.12"
                android:maxLines="1"
                android:text="@string/topbar_title"
                android:textColor="@color/tactical_warning"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/btnDarkModeToggle"
                app:layout_constraintStart_toEndOf="@id/topBarLogoPlate"
                app:layout_constraintTop_toTopOf="@id/topBarLogoPlate" />

            <TextView
                android:id="@+id/topBarSubtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:fontFamily="monospace"
                android:letterSpacing="0.08"
                android:maxLines="1"
                android:text="MISSION GRID"
                android:textColor="@color/tactical_muted"
                android:textSize="9sp"
                app:layout_constraintEnd_toStartOf="@id/topBarRegion"
                app:layout_constraintStart_toStartOf="@id/topBarTitle"
                app:layout_constraintTop_toBottomOf="@id/topBarTitle" />

            <TextView
                android:id="@+id/topBarRegion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_region_badge"
                android:fontFamily="monospace"
                android:letterSpacing="0.06"
                android:maxWidth="132dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:text="● BENGALURU"
                android:textColor="@color/tactical_chip_on"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/topBarLogoPlate"
                app:layout_constraintEnd_toStartOf="@id/btnDarkModeToggle"
                app:layout_constraintTop_toBottomOf="@id/topBarTitle" />

            <ImageButton
                android:id="@+id/btnDarkModeToggle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_action_button"
                android:contentDescription="@string/control_recenter"
                android:padding="11dp"
                android:src="@drawable/ic_location_pin"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <ImageButton
            android:id="@+id/btnCompassFloating"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_compass_button"
            android:contentDescription="@string/compass_description"
            android:elevation="10dp"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:src="@drawable/veer_rakshak_logo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/topBar" />

        <!-- ── ROUTE SUMMARY CARD ──────────────────── -->
        <!-- Visible only when a route is active -->
        <androidx.cardview.widget.CardView
            android:id="@+id/routeSummaryCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/card_margin_horizontal"
            android:layout_marginTop="8dp"
            android:elevation="@dimen/card_elevation"
            android:visibility="gone"
            app:cardBackgroundColor="@color/tactical_card"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/topBar">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <!-- Card header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.12"
                        android:text="@string/route_card_label"
                        android:textColor="@color/tactical_warning"
                        android:textSize="@dimen/text_label"
                        android:textStyle="bold" />

                    <!-- Route status chip -->
                    <TextView
                        android:id="@+id/routeStatusChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:text="@string/route_status_on"
                        android:textColor="@color/status_on_route"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <!-- Close button -->
                    <ImageButton
                        android:id="@+id/btnCloseRouteCard"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_marginStart="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/close_description"
                        android:src="@drawable/ic_close" />
                </LinearLayout>

                <!-- Destination name -->
                <TextView
                    android:id="@+id/routeDestinationText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="monospace"
                    android:text="Objective"
                    android:textColor="@color/tactical_on_dark"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Progress bar -->
                <ProgressBar
                    android:id="@+id/routeProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progress="50"
                    android:progressBackgroundTint="@color/progress_track"
                    android:progressTint="@color/tactical_warning" />

                <!-- Stats row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <!-- Remaining distance -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="@string/route_remaining"
                            android:textColor="@color/tactical_muted"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/routeRemainingText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="—"
                            android:textColor="@color/tactical_on_dark"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- ETA -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="@string/route_eta"
                            android:textColor="@color/tactical_muted"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/routeEtaText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="—"
                            android:textColor="@color/tactical_warning"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Total distance -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="@string/route_total"
                            android:textColor="@color/tactical_muted"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/routeTotalText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="—"
                            android:textColor="@color/tactical_on_dark"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── DESTINATION INFO PANEL ─────────────── -->
        <!-- Slides up from bottom when a destination is tapped -->
        <androidx.cardview.widget.CardView
            android:id="@+id/destinationPanel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/card_margin_horizontal"
            android:layout_marginBottom="12dp"
            android:elevation="@dimen/card_elevation"
            android:visibility="gone"
            app:cardBackgroundColor="@color/tactical_card_alt"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:layout_constraintBottom_toTopOf="@id/bottomCommandCard"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <!-- Header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_location_pin"
                        android:contentDescription="Objective" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.12"
                        android:text="@string/dest_panel_label"
                        android:textColor="@color/tactical_warning"
                        android:textSize="@dimen/text_label"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/btnCloseDestPanel"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/close_description"
                        android:src="@drawable/ic_close" />
                </LinearLayout>

                <!-- Destination name -->
                <TextView
                    android:id="@+id/destPanelName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="monospace"
                    android:text="Selected Point"
                    android:textColor="@color/tactical_on_dark"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Coordinates -->
                <TextView
                    android:id="@+id/destPanelCoords"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:fontFamily="monospace"
                    android:text="—"
                    android:textColor="@color/tactical_muted"
                    android:textSize="11sp" />

                <!-- Distance from operator -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:text="@string/dest_panel_distance_label"
                        android:textColor="@color/tactical_muted"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/destPanelDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:fontFamily="monospace"
                        android:text="—"
                        android:textColor="@color/tactical_on_dark"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Action buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnRouteHere"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_btn_primary_dark"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.08"
                        android:text="@string/dest_panel_route_btn"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnClearDest"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_btn_outline_amber"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.08"
                        android:text="@string/dest_panel_clear_btn"
                        android:textColor="@color/tactical_warning"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── HAZARD ZONE FAB ────────────────────── -->
        <!-- Tap to toggle hazard draw mode; long-press map to place a zone -->
        <ImageButton
            android:id="@+id/hazardFab"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="120dp"
            android:background="@drawable/bg_hazard_fab"
            android:contentDescription="Mark Hazard Zone"
            android:elevation="12dp"
            android:padding="12dp"
            android:src="@drawable/ic_hazard"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ── BOTTOM VOICE COMMAND CARD ──────────── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/bottomCommandCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/card_margin_horizontal"
            android:layout_marginBottom="@dimen/bottom_card_margin"
            android:elevation="@dimen/card_elevation"
            app:cardBackgroundColor="@color/tactical_card"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <!-- Card header row: label + mic indicator -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Mic icon -->
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_mic"
                        android:contentDescription="Microphone" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.12"
                        android:text="@string/voice_card_label"
                        android:textColor="@color/tactical_warning"
                        android:textSize="@dimen/text_label"
                        android:textStyle="bold" />

                    <!-- Pulsing mic status dot -->
                    <View
                        android:id="@+id/micIndicatorDot"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/mic_pulse_anim" />

                    <!-- Mic status label -->
                    <TextView
                        android:id="@+id/micStatusLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:text="LIVE"
                        android:textColor="@color/mic_active"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Live transcription -->
                <TextView
                    android:id="@+id/transcriptionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="monospace"
                    android:maxLines="3"
                    android:text="@string/voice_listening"
                    android:textColor="@color/tactical_secondary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Command examples hint -->
                <TextView
                    android:id="@+id/commandExamplesText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="monospace"
                    android:text="@string/voice_examples"
                    android:textColor="@color/tactical_muted"
                    android:textSize="11sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── STATUS TEXT (legacy, hidden, still used in code) ── -->
        <!-- We keep this invisible so existing code references don't crash -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="HardcodedText"
            android:text="" />

        <!-- Kept for code compatibility, text from routeSummaryCard replaces this -->
        <TextView
            android:id="@+id/routeSummaryText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:text="" />

        <FrameLayout
            android:id="@+id/launchOverlay"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@color/splash_bg"
            android:clickable="true"
            android:elevation="24dp"
            android:focusable="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <include layout="@layout/activity_splash" />
        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ════════════════════════════════════════════
         NAVIGATION DRAWER (slides in from left)
         ════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/navigationDrawer"
        android:layout_width="@dimen/drawer_width"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/tactical_drawer_bg"
        android:elevation="16dp"
        android:orientation="vertical">

        <!-- Drawer header (logo + title) -->
        <include layout="@layout/nav_drawer_header" />

        <!-- Drawer content (regions, toggles, controls) -->
        <include layout="@layout/nav_drawer_content" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
