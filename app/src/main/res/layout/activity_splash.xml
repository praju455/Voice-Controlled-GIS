<?xml version="1.0" encoding="utf-8"?>
<!-- Veer Rakshak Splash Screen -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bg">

    <!-- Subtle radial glow behind logo -->
    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_splash_glow" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Logo image (the Veer Rakshak compass) -->
        <ImageView
            android:id="@+id/splashLogo"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:contentDescription="Veer Rakshak Logo"
            android:src="@drawable/veer_rakshak_logo"
            android:scaleType="fitCenter" />

        <!-- App name -->
        <TextView
            android:id="@+id/splashTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.18"
            android:text="VEER RAKSHAK"
            android:textAllCaps="true"
            android:textColor="@color/tactical_warning"
            android:textSize="26sp"
            android:textStyle="bold" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/splashSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.12"
            android:text="@string/app_subtitle"
            android:textColor="@color/tactical_muted"
            android:textSize="13sp" />

        <!-- Divider line -->
        <View
            android:layout_width="120dp"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:background="@color/tactical_outline" />

        <!-- Build label -->
        <TextView
            android:id="@+id/splashBuild"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.10"
            android:text="@string/app_version"
            android:textColor="#405060"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- Loading indicator at bottom -->
    <TextView
        android:id="@+id/splashLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="48dp"
        android:fontFamily="monospace"
        android:letterSpacing="0.08"
        android:text="INITIALIZING OFFLINE SYSTEMS…"
        android:textColor="#30607080"
        android:textSize="10sp" />

</FrameLayout>
