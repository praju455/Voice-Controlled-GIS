<?xml version="1.0" encoding="utf-8"?>
<!-- Full Navigation Drawer Content (Sidebar) -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tactical_drawer_bg"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- ── REGIONS section ─────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="16dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.14"
            android:text="@string/drawer_section_regions"
            android:textColor="@color/tactical_warning"
            android:textSize="11sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="6dp"
            android:background="@color/tactical_divider" />

        <!-- Bengaluru Zone (active) -->
        <LinearLayout
            android:id="@+id/regionBengaluru"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_region_item"
            android:clickable="true"
            android:focusable="true"
            android:orientation="horizontal"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="@string/region_bengaluru"
                    android:textColor="@color/tactical_on_dark"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="monospace"
                    android:text="@string/region_bengaluru_sub"
                    android:textColor="@color/tactical_muted"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Active badge -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:background="@drawable/bg_btn_filled_amber"
                android:fontFamily="monospace"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="ACTIVE"
                android:textColor="#0D1E23"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Siachen Border -->
        <LinearLayout
            android:id="@+id/regionSiachen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_region_item"
            android:clickable="true"
            android:focusable="true"
            android:orientation="horizontal"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="@string/region_siachen"
                    android:textColor="@color/tactical_on_dark"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="monospace"
                    android:text="@string/region_siachen_sub"
                    android:textColor="@color/tactical_muted"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:background="@drawable/bg_btn_outline_amber"
                android:fontFamily="monospace"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="DEMO"
                android:textColor="@color/tactical_warning"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Line of Control -->
        <LinearLayout
            android:id="@+id/regionLoC"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_region_item"
            android:clickable="true"
            android:focusable="true"
            android:orientation="horizontal"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="@string/region_loc"
                    android:textColor="@color/tactical_on_dark"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="monospace"
                    android:text="@string/region_loc_sub"
                    android:textColor="@color/tactical_muted"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:background="@drawable/bg_btn_outline_amber"
                android:fontFamily="monospace"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="DEMO"
                android:textColor="@color/tactical_warning"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- ── DISPLAY section ─────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="16dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.14"
            android:text="@string/drawer_section_display"
            android:textColor="@color/tactical_warning"
            android:textSize="11sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="6dp"
            android:background="@color/tactical_divider" />

        <!-- Dark mode placeholder -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_dark_mode"
                android:contentDescription="Dark mode" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:text="@string/toggle_dark_mode"
                android:textColor="@color/tactical_on_dark"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="COMING SOON"
                android:textColor="@color/tactical_muted"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Operator Marker Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_recenter"
                android:contentDescription="Operator marker" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:text="@string/toggle_operator_marker"
                android:textColor="@color/tactical_on_dark"
                android:textSize="13sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchOperatorMarker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:theme="@style/SwitchTactical" />
        </LinearLayout>

        <!-- ── MAP CONTROLS section ────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="16dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.14"
            android:text="@string/drawer_section_controls"
            android:textColor="@color/tactical_warning"
            android:textSize="11sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="6dp"
            android:background="@color/tactical_divider" />

        <!-- Recenter button -->
        <LinearLayout
            android:id="@+id/btnDrawerRecenter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_btn_outline_amber"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_recenter"
                android:contentDescription="Recenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="monospace"
                android:text="@string/control_recenter"
                android:textColor="@color/tactical_warning"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Clear Route button -->
        <LinearLayout
            android:id="@+id/btnDrawerClearRoute"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_btn_outline_amber"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_route"
                android:contentDescription="Clear route" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="monospace"
                android:text="@string/control_clear_route"
                android:textColor="@color/tactical_warning"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Clear Destination button -->
        <LinearLayout
            android:id="@+id/btnDrawerClearDestination"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_btn_outline_amber"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_location_pin"
                android:contentDescription="Clear destination" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="monospace"
                android:text="@string/control_clear_destination"
                android:textColor="@color/tactical_warning"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Clear Hazards button -->
        <LinearLayout
            android:id="@+id/btnDrawerClearHazards"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_btn_outline_amber"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_hazard"
                android:contentDescription="Clear hazards" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="monospace"
                android:text="@string/control_clear_hazards"
                android:textColor="@color/tactical_warning"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- ── TEAM MESH section ───────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="16dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.14"
            android:text="TEAM MESH"
            android:textColor="#00E5FF"
            android:textSize="11sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="6dp"
            android:background="@color/tactical_divider" />

        <!-- My callsign row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="MY CALLSIGN:"
                android:textColor="@color/tactical_muted"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/myCallsignLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:text="ALPHA-1"
                android:textColor="#00E5FF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnEditCallsign"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/bg_btn_outline_amber"
                android:fontFamily="monospace"
                android:paddingHorizontal="10dp"
                android:text="EDIT"
                android:textColor="@color/tactical_warning"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Team status count -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/meshStatusDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/ic_hazard" />

            <TextView
                android:id="@+id/meshStatusText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:text="◌  SOLO — no peers"
                android:textColor="@color/tactical_muted"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Team member list container -->
        <LinearLayout
            android:id="@+id/teamMemberList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="8dp"
            android:orientation="vertical" />

        <!-- Setup hint -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:fontFamily="monospace"
            android:text="▸ One device creates a Mobile Hotspot\n▸ All others join that Wi-Fi\n▸ Positions sync automatically"
            android:textColor="@color/tactical_muted"
            android:textSize="10sp" />

        <!-- Spacer / Footer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="28dp"
            android:background="@color/tactical_divider" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:text="AIR-GAPPED · OFFLINE · SECURE"
            android:textColor="#25607A85"
            android:textSize="9sp" />

    </LinearLayout>
</ScrollView>
