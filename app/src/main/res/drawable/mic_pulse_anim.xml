<?xml version="1.0" encoding="utf-8"?>
<!-- Animated mic pulse frames: green dot that fades in/out -->
<animation-list xmlns:android="http://schemas.android.com/apk/res/android"
    android:oneshot="false">
    <item android:duration="400">
        <shape xmlns:android="http://schemas.android.com/apk/res/android"
            android:shape="oval">
            <solid android:color="#FF2ECC71" />
            <size android:width="10dp" android:height="10dp" />
        </shape>
    </item>
    <item android:duration="400">
        <shape xmlns:android="http://schemas.android.com/apk/res/android"
            android:shape="oval">
            <solid android:color="#882ECC71" />
            <size android:width="10dp" android:height="10dp" />
        </shape>
    </item>
    <item android:duration="400">
        <shape xmlns:android="http://schemas.android.com/apk/res/android"
            android:shape="oval">
            <solid android:color="#FF2ECC71" />
            <size android:width="10dp" android:height="10dp" />
        </shape>
    </item>
</animation-list>
