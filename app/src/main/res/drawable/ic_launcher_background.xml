<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#11170F"
                android:endColor="#273322" />
        </shape>
    </item>
    <item
        android:left="18dp"
        android:top="18dp"
        android:right="18dp"
        android:bottom="18dp">
        <shape android:shape="oval">
            <solid android:color="#1B2417" />
            <stroke
                android:width="1dp"
                android:color="#556E51" />
        </shape>
    </item>
</layer-list>
