<?xml version="1.0" encoding="utf-8"?>
<!-- FAB background - amber when idle, red when hazard mode active -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#A63C201C" />
        </shape>
    </item>
    <item android:state_checked="true">
        <shape android:shape="oval">
            <solid android:color="#B6422723" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="#D7BF7A" />
            <stroke
                android:width="1dp"
                android:color="#6C7D57" />
        </shape>
    </item>
</selector>
