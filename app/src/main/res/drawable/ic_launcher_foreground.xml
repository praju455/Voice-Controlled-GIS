<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:width="88dp"
        android:height="88dp"
        android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="#26311F" />
            <stroke
                android:width="1dp"
                android:color="#D7BF7A" />
        </shape>
    </item>
    <item
        android:width="78dp"
        android:height="78dp"
        android:gravity="center">
        <bitmap
            android:antialias="true"
            android:gravity="center"
            android:src="@drawable/veer_rakshak_logo" />
    </item>
</layer-list>
