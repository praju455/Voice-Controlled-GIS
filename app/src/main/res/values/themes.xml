<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ── Tactical Dark (default) ── -->
    <style name="Theme.TacticalMap" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/tactical_primary</item>
        <item name="colorPrimaryVariant">@color/tactical_primary_variant</item>
        <item name="colorOnPrimary">@color/tactical_on_dark</item>
        <item name="colorSecondary">@color/tactical_secondary</item>
        <item name="colorSecondaryVariant">@color/tactical_secondary_variant</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">@color/tactical_surface</item>
        <item name="android:navigationBarColor">@color/tactical_surface</item>
        <item name="android:windowBackground">@color/tactical_surface</item>
        <item name="android:textColorPrimary">@color/tactical_on_dark</item>
        <item name="android:textColorSecondary">@color/tactical_muted</item>
    </style>

    <!-- ── Standard Light / Day ── -->
    <style name="Theme.TacticalMap.Day" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/day_primary</item>
        <item name="colorPrimaryVariant">@color/day_primary_variant</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/day_secondary</item>
        <item name="colorSecondaryVariant">@color/day_secondary_variant</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/day_primary_variant</item>
        <item name="android:navigationBarColor">@color/day_primary_variant</item>
        <item name="android:windowBackground">@color/day_surface</item>
        <item name="android:textColorPrimary">@color/day_on_surface</item>
        <item name="android:textColorSecondary">@color/day_muted</item>
    </style>

    <!-- ── Splash screen theme ── -->
    <style name="Theme.TacticalMap.Splash" parent="Theme.TacticalMap">
        <item name="android:windowBackground">@color/splash_bg</item>
        <item name="android:statusBarColor">@color/splash_bg</item>
        <item name="android:navigationBarColor">@color/splash_bg</item>
    </style>

    <!-- ── Switch amber style for sidebar toggles ── -->
    <style name="SwitchTactical" parent="Widget.AppCompat.CompoundButton.Switch">
        <item name="colorControlActivated">@color/tactical_warning</item>
        <item name="colorSwitchThumbNormal">@color/tactical_muted</item>
        <item name="android:colorForeground">@color/tactical_muted</item>
    </style>

</resources>
