{
  "version": 8,
  "name": "Offline Tactical Style",
  "sources": {
    "tactical_offline_source": {
      "type": "raster",
      "tiles": ["{PLACEHOLDER_PATH}"],
      "tileSize": 256,
      "bounds": [{PLACEHOLDER_BOUNDS}],
      "minzoom": {PLACEHOLDER_MIN_ZOOM},
      "maxzoom": {PLACEHOLDER_MAX_ZOOM}
    }
  },
  "layers": [
    {
      "id": "tactical_background",
      "type": "background",
      "paint": {
        "background-color": "#08141a"
      }
    },
    {
      "id": "tactical_offline_layer",
      "type": "raster",
      "source": "tactical_offline_source",
      "paint": {}
    }
  ]
}
